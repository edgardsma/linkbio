{
  "name": "linkbio-brasil",
  "version": "1.0.0",
  "description": "Sua página de links personalizada - Crie e compartilhe todos os seus links em um único lugar!",
  "main": "index.js",
  "scripts": {
    "dev": "node scripts/dev-with-prisma.js",
    "dev:docker": "docker-compose -f docker-compose.dev.yml up -d",
    "dev:docker-down": "docker-compose -f docker-compose.dev.yml down",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "test:unit": "jest __tests__/unit",
    "test:integration": "jest __tests__/integration",
    "test:e2e": "playwright test",
    "test:new": "node scripts/test-new-features.js",
    "test:db": "node scripts/test.js --db-only",
    "test:api": "node scripts/test.js --api-only",
    "test:themes": "node scripts/test.js --themes-only",
    "seed:themes": "curl -X POST http://localhost:3000/api/seed",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio --port 5555 --browser none",
    "studio": "prisma studio --port 5555",
    "prisma:dev": "prisma dev",
    "icons": "node scripts/generate-icons.mjs",
    "postinstall": "prisma generate"
  },
  "keywords": [
    "linkbio",
    "linktree",
    "links",
    "bio",
    "pagina-de-links",
    "nextjs",
    "prisma",
    "tailwind"
  ],
  "author": "LinkBio Brasil",
  "license": "MIT",
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/client": "^5.22.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/uuid": "^10.0.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.3",
    "autoprefixer": "^10.4.27",
    "bcryptjs": "^3.0.3",
    "driver.js": "^1.4.0",
    "jsonwebtoken": "^9.0.3",
    "next": "^16.1.6",
    "next-auth": "^4.24.13",
    "postcss": "^8.5.8",
    "prisma": "^5.22.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^6.9.3",
    "stripe": "^20.4.0",
    "tailwindcss": "^4.2.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^25.3.3",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "eslint": "^9.24.0",
    "eslint-config-next": "^15.3.2",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "typescript": "^5.9.3"
  }
}
