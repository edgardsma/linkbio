generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String        @id @default(cuid())
  email               String        @unique
  emailVerified        DateTime?
  name                String?
  username            String        @unique
  password            String?
  image               String?
  bio                 String?
  background          String?
  primaryColor        String        @default("#667eea")
  secondaryColor      String        @default("#764ba2")
  backgroundColor     String        @default("#f9fafb")
  textColor           String        @default("#111827")
  buttonStyle         String        @default("rounded")
  fontFamily          String        @default("inter")
  themeId             String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  role                String        @default("user")
  agencyId            String?
  onboardingDismissed Boolean       @default(false)
  accounts            Account[]
  links               Link[]
  sessions            Session[]
  subscription         Subscription?
  theme               Theme?        @relation(fields: [themeId], references: [id])
  passwordResetTokens PasswordResetToken[]
  shortLinks          ShortLink[]
}

model Theme {
  id              String   @id @default(cuid())
  name            String   @unique
  category        String   @default("Geral")
  isPremium       Boolean  @default(false)
  primaryColor    String
  secondaryColor  String
  backgroundColor String
  textColor       String
  buttonStyle     String   @default("rounded")
  fontFamily      String   @default("inter")
  description     String?
  previewImage    String?
  createdAt       DateTime @default(now())
  users           User[]
}

model Link {
  id          String   @id @default(cuid())
  title       String
  url         String
  description String?
  icon        String?
  type        String   @default("url")
  position    Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  clicks      Int      @default(0)
  userId      String
  clickLogs   Click[]
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([position])
}

model Click {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userAgent String?
  referrer  String?
  country   String?
  city      String?
  linkId    String
  link      Link     @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@index([linkId])
  @@index([createdAt])
  @@index([linkId, createdAt]) // analytics: queries com filtro de data por link
}

model Subscription {
  id                String    @id @default(cuid())
  status            String
  plan              String
  stripeCustomerId  String?
  stripePriceId     String?
  currentPeriodEnd  DateTime?
  cancelAtPeriodEnd Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expires   DateTime
  createdAt DateTime @default(now())
  used      Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model ShortLink {
  id          String          @id @default(cuid())
  userId      String?
  originalUrl String
  slug        String          @unique
  clicks      Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  clickLogs   ShortLinkClick[]
  user        User?           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([slug])
  @@index([userId])
  @@index([createdAt])
}

model ShortLinkClick {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())
  userAgent   String?
  referrer    String?
  country     String?
  device      String?
  shortLinkId String
  shortLink   ShortLink @relation(fields: [shortLinkId], references: [id], onDelete: Cascade)

  @@index([shortLinkId])
  @@index([createdAt])
  @@index([shortLinkId, createdAt])
}
