# Configuração do Banco de Dados
# Execute 'npx prisma dev' para iniciar o PostgreSQL local
DATABASE_URL="prisma+postgres://localhost:51213/?api_key=..."

# Configuração do NextAuth.js
# Gere uma chave secreta com: openssl rand -base64 32
NEXTAUTH_SECRET="sua-chave-secreta-aqui-mude-isso"
NEXTAUTH_URL="http://localhost:3000"

# Provedores OAuth (Opcional - para login com redes sociais)
# Google OAuth - Obtenha em: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub OAuth - Obtenha em: https://github.com/settings/developers
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Facebook OAuth - Obtenha em: https://developers.facebook.com/
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# Stripe (Opcional - para pagamentos premium)
# Obtenha em: https://dashboard.stripe.com/
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PUBLISHABLE_KEY=""

# Price IDs do Stripe (criados no Dashboard)
# Para criar: https://dashboard.stripe.com/products
# ATENÇÃO: Atualize também em lib/stripe-config.js

# Planos Starter
STRIPE_PRICE_STARTER_MONTHLY="price_starter_1"
STRIPE_PRICE_STARTER_ANNUAL="price_starter_1_year"

# Planos Pro
STRIPE_PRICE_PRO_MONTHLY="price_pro_1"
STRIPE_PRICE_PRO_ANNUAL="price_pro_1_year"

# Planos Premium
STRIPE_PRICE_PREMIUM_MONTHLY="price_premium_1"
STRIPE_PRICE_PREMIUM_ANNUAL="price_premium_1_year"

# Configurações de Email (Opcional - para envio de emails)
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM=""
