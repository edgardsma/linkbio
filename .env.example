# Configuração do Banco de Dados
# Execute 'npx prisma dev' para iniciar o PostgreSQL local
DATABASE_URL="prisma+postgres://localhost:51213/?api_key=..."

# Configuração do NextAuth.js
# Gere uma chave secreta com: openssl rand -base64 32
NEXTAUTH_SECRET="sua-chave-secreta-aqui-mude-isso"
NEXTAUTH_URL="http://localhost:3000"

# Provedores OAuth (Opcional - para login com redes sociais)
# Google OAuth - Obtenha em: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub OAuth - Obtenha em: https://github.com/settings/developers
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Facebook OAuth - Obtenha em: https://developers.facebook.com/
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# ==============================================================================
# CONFIGURAÇÃO DO STRIPE
# ==============================================================================
#
# PASSO 1: Acesse https://dashboard.stripe.com/test/apikeys
# PASSO 2: Crie uma conta de teste ou use suas credenciais existentes
# PASSO 3: Copie as chaves abaixo e cole no arquivo .env
#
# NOTA: Para desenvolvimento, use as chaves de teste (pk_test_, sk_test_)
#         Para produção, use as chaves de produção (pk_live_, sk_live_)
#
# ==============================================================================

# Chaves do Stripe (SUBSTITUA PELAS SUAS CREDENCIAIS)
# Use chaves de teste para desenvolvimento
STRIPE_SECRET_KEY="sk_test_sua_chave_secreta_aqui"
STRIPE_PUBLISHABLE_KEY="pk_test_sua_chave_publicavel_aqui"
STRIPE_WEBHOOK_SECRET="whsec_sua_chave_webhook_aqui"

# ==============================================================================
# CRIAÇÃO DE PREÇOS NO STRIPE
# ==============================================================================
#
# PASSO 1: Acesse https://dashboard.stripe.com/test/products
# PASSO 2: Clique em "Criar produto" para cada plano
# PASSO 3: Configure cada produto conforme abaixo:
#
# Para cada produto, crie 2 preços (mensal e anual) com estes dados:
#
# PLANO STARTER - Mensal:
#   - Nome: Starter (Mensal)
#   - Preço: 19.90
#   - Moeda: BRL
#   - Tipo: Recorrente
#   - Faturamento: Mensal
#
# PLANO STARTER - Anual:
#   - Nome: Starter (Anual)
#   - Preço: 199.90
#   - Moeda: BRL
#   - Tipo: Recorrente
#   - Faturamento: Anual
#   - Período: 1 ano
#
# PLANO PRO - Mensal:
#   - Nome: Pro (Mensal)
#   - Preço: 49.90
#   - Moeda: BRL
#   - Tipo: Recorrente
#   - Faturamento: Mensal
#
# PLANO PRO - Anual:
#   - Nome: Pro (Anual)
#   - Preço: 499.90
#   - Moeda: BRL
#   - Tipo: Recorrente
#   - Faturamento: Anual
#   - Período: 1 ano
#
# PLANO PREMIUM - Mensal:
#   - Nome: Premium (Mensal)
#   - Preço: 99.90
#   - Moeda: BRL
#   - Tipo: Recorrente
#   - Faturamento: Mensal
#
# PLANO PREMIUM - Anual:
#   - Nome: Premium (Anual)
#   - Preço: 999.90
#   - Moeda: BRL
#   - Tipo: Recorrente
#   - Faturamento: Anual
#   - Período: 1 ano
#
# PASSO 4: Após criar os preços, copie os Price IDs conforme o formato:
#   price_starter_monthly_id
#   price_starter_annual_id
#   price_pro_monthly_id
#   price_pro_annual_id
#   price_premium_monthly_id
#   price_premium_annual_id
#
# ==============================================================================
# CONFIGURAÇÃO DE WEBHOOK
# ==============================================================================
# PASSO 5: Configure o webhook em: https://dashboard.stripe.com/test/webhooks
# PASSO 6: Configure os eventos:
#   - checkout.session.completed
#   - customer.subscription.created
#   - customer.subscription.updated
#   - customer.subscription.deleted
#   - invoice.payment_succeeded
# PASSO 7: Copie a "Signing Secret" e cole abaixo:
STRIPE_WEBHOOK_SECRET="whsec_sua_chave_webhook_aqui"

# PASSO 8: Configure a URL do webhook:
#   - URL: http://localhost:3000/api/stripe/webhook (desenvolvimento)
#   - URL: https://seu-dominio.com/api/stripe/webhook (produção)
#
# ==============================================================================

# Price IDs do Stripe (Cole os IDs criados no passo 4)
# ==============================================================================
#
# ATENÇÃO: Substitua os valores abaixo pelos Price IDs reais do Stripe
#

# Plano Starter - Mensal
STRIPE_PRICE_STARTER_MONTHLY="price_starter_monthly_id"

# Plano Starter - Anual
STRIPE_PRICE_STARTER_ANNUAL="price_starter_annual_id"

# Plano Pro - Mensal
STRIPE_PRICE_PRO_MONTHLY="price_pro_monthly_id"

# Plano Pro - Anual
STRIPE_PRICE_PRO_ANNUAL="price_pro_annual_id"

# Plano Premium - Mensal
STRIPE_PRICE_PREMIUM_MONTHLY="price_premium_monthly_id"

# Plano Premium - Anual
STRIPE_PRICE_PREMIUM_ANNUAL="price_premium_annual_id"

# ==============================================================================
# CONFIGURAÇÕES DE EMAIL (Opcional - para envio de emails)
# ==============================================================================
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM=""

# ==============================================================================
# CONFIGURAÇÕES ADICIONAIS
# ==============================================================================
NODE_ENV="development"

# Redis (Opcional - para cache e rate limiting)
REDIS_URL=""
REDIS_TOKEN=""

# Variáveis de Ambiente do Vercel (para deploy)
VERCEL_GITHUB_ID=""
VERCEL_GITHUB_TOKEN=""
